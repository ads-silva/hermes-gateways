{
  "name": "hermes-gateways",
  "version": "1.0.0",
  "description": "Pluggable chat-gateway layer for the Hermes Agent (Discord today, more later)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "bullmq": "^5.34.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "ioredis": "5.10.1",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
